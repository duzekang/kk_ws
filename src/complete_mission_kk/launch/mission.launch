<launch> 
	<!--设置静态坐标系 -->
    <node pkg="tf" type="static_transform_publisher"  name="robot_foot_init_link_to_camera_link" args="0 0 0 0 0 0 robot_foot_init camera_link 100" />

    <node pkg="tf" type="static_transform_publisher"  name="robot_foot_init_link_to_base_link"  args="0 0 0.1 0 0 0 robot_foot_init base_link 100" />     


    <include file="$(find mavros)/launch/px4.launch" />
    
    <include file="$(find livox_ros_driver2)/launch/msg_MID360.launch" />
    
    <node name='lidar_to_mavros' pkg="lidar_to_mavros" type="lidar_to_mavros" />
    
	<!--include file="$(find usb_cam)/launch/usb_cam-test.launch" /-->
	
	<!--include file="$(find robot_vision)/launch/ar_track_camera.launch" /--> 
	
	<!--include file="$(find astra_camera)/launch/gemini.launch" /-->
	
    <!--include file="$(find darknet_ros)/launch/darknet_ros.launch" /--> 
	
	<!--include file="$(find object_darknet)/launch/object_darknet.launch" /--> 
    
    <include file="$(find slam_navigation)/launch/test_location.launch" />
    
    <include file="$(find navigation)/launch/test.launch" />
    
    <!--node name='ros_nav_quadrotor_node' pkg="px4_command" type="ros_nav_quadrotor_node" output="screen" /-->

</launch>

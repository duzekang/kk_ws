<launch>
    <!-- 障碍物1: 近处上方 -->
    <param name="obs_1_x" value="-2.1" />
    <param name="obs_1_y" value="-0.8" />
    
    <!-- 障碍物2: 近处下方 -->
    <param name="obs_2_x" value="-2.7" />
    <param name="obs_2_y" value="-0.8" />
    
    <!-- 障碍物3: 远处上方 -->
    <param name="obs_3_x" value="-2.1" />
    <param name="obs_3_y" value="-2.05" />
    
    <!-- 障碍物4: 远处下方 -->
    <param name="obs_4_x" value="-2.7" />
    <param name="obs_4_y" value="-2.05" />

    <!-- Z轴高度过滤 (关键！Mid360会扫到地面，必须卡准障碍物高度) -->
    <param name="z_min" value="-0.6" />
    <param name="z_max" value="2.5" />

    <param name="target_x" value="-2.10" />
    <param name="target_y" value="0.0" />
    <param name="position_threshold" value="0.3" />

    <param name="window_duration" value="3.0" />

    <param name="half_size" value="0.30" />
    
    <node pkg="obstacle_detector" type="obstacle_detector_node" name="detector" output="screen">
    </node>
</launch>